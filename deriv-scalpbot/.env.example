# ============================================================================
# DERIV API CONFIGURATION
# Get credentials from: https://api.deriv.com/dashboard
# IMPORTANT: Use DEMO/VIRTUAL account for testing!
# ============================================================================
DERIV_APP_ID=your_app_id_here
DERIV_API_TOKEN=your_api_token_here
DERIV_ACCOUNT_ID=your_account_id_here

# ============================================================================
# CONTRACT SETTINGS
# ============================================================================
CONTRACT_DURATION=5
CONTRACT_DURATION_UNIT=t
BASE_STAKE_USD=0.50
MAX_STAKE_USD=2.00
BUILDER_WINS_THRESHOLD=5
BUILDER_INCREMENT=0.05
MAX_SLIPPAGE_PIPS=0.5

# ============================================================================
# TELEGRAM CONFIGURATION
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ENABLE_TRADE_ALERTS=true

# ============================================================================
# TRADING SYMBOLS (Deriv format: frxEURUSD, frxGBPUSD, frxAUDUSD, etc.)
# ============================================================================
TRADING_SYMBOLS=frxEURUSD,frxGBPUSD,frxAUDUSD

# ============================================================================
# RISK MANAGEMENT
# ============================================================================
DAILY_LOSS_LIMIT_USD=5.00
ENABLE_DAILY_LOSS_LIMIT=true
MAX_POSITIONS=3
